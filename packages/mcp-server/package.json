{
  "name": "@ourthinktank/founders-os",
  "version": "1.2.0",
  "description": "MCP server for Founders OS — CRM, tasks, finances, feeds, memory, and visual surfaces from any MCP-compatible AI tool.",
  "author": "OurThinkTank",
  "license": "MIT",
  "type": "module",
  "bin": {
    "founders-os": "./dist/index.js",
    "founders-os-tick": "./dist/tick.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && cp -r demos dist/demos && rm -f dist/demos/HOW_TO_CREATE_DEMOS.md",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:demos": "vitest run src/__tests__/demo-tool-params.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.800.0",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@ourthinktank/founders-os-core": "*",
    "@supabase/supabase-js": "^2.49.4",
    "openai": "^4.100.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.196"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OurThinkTank/founders-os.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://foundersmcp.com",
  "bugs": {
    "url": "https://github.com/OurThinkTank/founders-os/issues"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "crm",
    "founders",
    "startup",
    "small-business",
    "claude",
    "ai-tools",
    "supabase"
  ]
}
