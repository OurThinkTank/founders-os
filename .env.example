# ============================================================
# Founders OS — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# For Claude Desktop / Claude Code, set these in the "env"
# block of your MCP server config instead of a .env file.
# ============================================================

# ── Supabase (required for all tools) ───────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# ── Identity (optional, recommended for everyone) ────────────
# Identifies the current user for personal memory scope.
# If unset, the server runs as the sample user "foundersuser1"
# and will remind you to set a real value. Pick something that
# identifies you (e.g. "alice", "bob"); each team member should
# set a distinct value so personal memory scope works correctly.
FOUNDERS_OS_USER_ID=your-username

# ── Embedding provider (required for memory tools) ───────────
# Options: bedrock | openai | ollama
# Default: openai
EMBEDDING_PROVIDER=openai

# Model to use — provider-specific defaults shown below:
#   bedrock default : amazon.nova-2-multimodal-embeddings-v1:0  (1024 dims)
#   openai  default : text-embedding-3-small                    (1536 dims)
#   ollama  default : nomic-embed-text                          (768 dims)
EMBEDDING_MODEL=text-embedding-3-small

#  EMBEDDING_DIM must match the vector() size in supabase/setup.sql.
#     Set this BEFORE running setup. Never change it after.
#     bedrock/nova = 1024  |  openai/3-small = 1536  |  ollama/nomic = 768
EMBEDDING_DIM=1536

# ── AWS Bedrock credentials ──────────────────────────────────
# Uses standard AWS credential chain: env vars → ~/.aws → IAM role.
# No explicit key needed when running on AWS with an attached IAM role.
AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...        # only needed outside AWS / without IAM role
# AWS_SECRET_ACCESS_KEY=...

# ── OpenAI (only required if EMBEDDING_PROVIDER=openai) ──────
# OPENAI_API_KEY=sk-...

# ── Ollama (only required if EMBEDDING_PROVIDER=ollama) ──────
# OLLAMA_BASE_URL=http://localhost:11434

# ── Company / tenant identity ────────────────────────────────
# Identifies which company's data (CRM, finances, memory, etc.)
# to read and write. If unset, the server runs as the sample
# company "myawesomecompany" and will remind you to set a real
# value. Change it to a unique slug for your org. Everyone on the
# same Supabase project using the same value shares that company's
# data.
FOUNDERS_OS_COMPANY_ID=your-company-id
